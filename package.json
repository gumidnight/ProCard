{
  "name": "rankcard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:worker": "opennextjs-cloudflare",
    "preview": "pnpm build:worker && wrangler dev",
    "deploy": "pnpm build:worker && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply rankcard-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply rankcard-db --remote",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "lint": "eslint ."
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "framer-motion": "^12.38.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.8",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.90.0"
  }
}
