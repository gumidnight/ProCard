{
  "name": "procard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:worker": "opennextjs-cloudflare build",
    "preview": "pnpm build:worker && wrangler dev",
    "deploy": "pnpm build:worker && node scripts/patch-handler.mjs && wrangler deploy --env production --no-bundle --config wrangler.patched.toml",
    "db:migrate:local": "wrangler d1 migrations apply procard-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply procard-db --remote",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "coverage": "vitest run --coverage",
    "validate:secrets": "node scripts/assert-secrets.mjs",
    "prepare": "husky"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.17.0",
    "next": "15.5.18",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "3",
    "wrangler": "^4.90.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "workerd"
    ]
  }
}
